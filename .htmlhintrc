{
  "doctype-first":         true,
  "tagname-lowercase":     true,
  "attr-lowercase":        true,
  "attr-value-double-quotes": true,
  "attr-no-duplication":   true,
  "tag-pair":              true,
  "id-unique":             true,
  "src-not-empty":         true,
